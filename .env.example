# ─── Database ────────────────────────────────────────────────────────────────
# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:yourpassword@localhost:3306/bizflow"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate a strong secret: run  openssl rand -base64 32  in your terminal
NEXTAUTH_SECRET="your-super-secret-key-here"

# The URL where your app runs (change to your Vercel URL when deploying)
NEXTAUTH_URL="http://localhost:3000"

# ─── Notes ───────────────────────────────────────────────────────────────────
# 1. Copy this file to .env and fill in your real values
#    cp .env.example .env
#
# 2. Never commit the actual .env file — it is already in .gitignore
#
# 3. For Vercel deployment, add these as Environment Variables in the
#    Vercel dashboard (Settings → Environment Variables)
#    Use your PlanetScale / Railway / Supabase MySQL URL for DATABASE_URL
