generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model BusinessConfig {
  id           Int      @id @default(autoincrement())
  adminId      Int      @unique
  businessName String
  ownerName    String
  phone        String
  type         String
  prices       Json
  createdAt    DateTime @default(now())
}

// ─── Customer ───────────────────────────────────────────────────────────────
model Customer {
  id        Int       @id @default(autoincrement())
  adminId   Int
  name      String
  phone     String
  address   String?
  isDeleted Boolean   @default(false)   // FIX: soft-delete support
  createdAt DateTime  @default(now())
  services  Service[]
  bills     Bill[]

  @@unique([phone, adminId])
}

// ─── Service ────────────────────────────────────────────────────────────────
model Service {
  id         Int      @id @default(autoincrement())
  adminId    Int
  customerId Int
  billId     Int?                       // FIX: links service to the bill it was included in (null = unbilled)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bill       Bill?    @relation(fields: [billId],     references: [id], onDelete: SetNull)
  type       String
  quantity   Int
  price      Float
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt  // FIX: track when status was last changed
}

// ─── Bill ───────────────────────────────────────────────────────────────────
model Bill {
  id            Int       @id @default(autoincrement())
  adminId       Int
  customerId    Int
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subtotal      Float     @default(0)   // FIX: amount before GST
  gstRate       Float     @default(0)   // FIX: GST percentage applied (0 = no GST)
  gstAmount     Float     @default(0)   // FIX: actual GST rupee amount
  total         Float                   // final amount (subtotal + gstAmount)
  invoiceNo     String?                 // AUTO: e.g. INV-2025-0001 (auto-generated)
  isPaid        Boolean   @default(false) // FIX: payment tracking
  paymentMethod String?                 // FIX: cash / upi / card
  paidAt        DateTime?               // FIX: when it was marked paid
  services      Service[]               // FIX: which services are in this bill
  createdAt     DateTime  @default(now())
}
